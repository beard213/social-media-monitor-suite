APP_NAME=社交媒体及网络直播监测与溯源系统
ENVIRONMENT=development

DATABASE_URL=sqlite:///./data/monitor.db
STORAGE_ROOT=./data/storage

DETECTOR_ENABLED=true
DETECTOR_BASE_URL=http://127.0.0.1:8080

LEGACY_DOUYIN_API_URL=http://127.0.0.1:18001
LEGACY_DOUYIN_OUTPUT_ROOT=/opt/social-monitor/data/douyin_live_dataset
LEGACY_DOUYIN_MAX_ROUNDS=0
LEGACY_DOUYIN_MAX_WORKERS=1
LEGACY_DOUYIN_SYNC_INTERVAL_SECONDS=15
LEGACY_DOUYIN_SYNC_MAX_CHECKS=40

DEFAULT_SEGMENT_SECONDS=120
HTTP_TIMEOUT_SECONDS=60

ADMIN_API_KEY=
ANONYMIZATION_SALT=replace-with-random-secret
