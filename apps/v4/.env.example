APP_NAME=社交媒体及网络直播监测与溯源系统
ENVIRONMENT=development
ADMIN_API_KEY=
DATABASE_URL=sqlite:///./data/monitor.db
STORAGE_ROOT=./data/storage

# 外部多模态检测服务
DETECTOR_BASE_URL=http://127.0.0.1:8080
DETECTOR_ENABLED=false

# 推送给其他项目方（默认标注为赵帅项目方）
PUSH_ENABLED=false
PUSH_TARGET_NAME=赵帅项目方
PUSH_EVENTS_URL=
PUSH_MEDIA_URL=
PUSH_BEARER_TOKEN=

# 已完成的“输入直播ID进行监控”服务，可通过这个桥接地址接入
# 约定：POST {URL}/v1/live/resolve，详见 docs/直播ID接入协议.md
LIVE_MONITOR_BRIDGE_URL=
LIVE_MONITOR_BRIDGE_TOKEN=

ANONYMIZATION_SALT=replace-this-with-a-random-secret
DEFAULT_SEGMENT_SECONDS=120
HTTP_TIMEOUT_SECONDS=60

# 任务中心 -> 抖音授权连接器（赵帅填写）
DOUYIN_CONNECTOR_URL=
DOUYIN_CONNECTOR_TOKEN=

# 任务中心 -> 快手授权连接器（赵帅填写）
KUAISHOU_CONNECTOR_URL=
KUAISHOU_CONNECTOR_TOKEN=

# true 时自动生成虚构演示数据；真实部署可改为 false
DEMO_PROVIDER_ENABLED=true

# 旧抖音直播ID采集/转写/检测项目集成
LEGACY_DOUYIN_API_URL=http://127.0.0.1:8000
LEGACY_DOUYIN_OUTPUT_ROOT=/data/comment-backend-douyin-live/output/douyin_live_dataset
LEGACY_DOUYIN_MAX_ROUNDS=1
LEGACY_DOUYIN_MAX_WORKERS=1
LEGACY_DOUYIN_SYNC_INTERVAL_SECONDS=15
LEGACY_DOUYIN_SYNC_MAX_CHECKS=40
