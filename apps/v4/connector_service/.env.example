# 每个连接器服务只运行一个平台：douyin 或 kuaishou
CONNECTOR_PLATFORM=douyin
CONNECTOR_INTERNAL_TOKEN=replace-with-random-token

# 抖音授权凭证空位
DOUYIN_CLIENT_KEY=
DOUYIN_CLIENT_SECRET=
DOUYIN_ACCESS_TOKEN=
DOUYIN_REFRESH_TOKEN=
DOUYIN_OPEN_ID=

# 快手授权凭证空位
KUAISHOU_APP_ID=
KUAISHOU_APP_SECRET=
KUAISHOU_ACCESS_TOKEN=

# 任务中心地址，用于主动推送授权直播互动事件
TASK_CENTER_BASE_URL=http://127.0.0.1:18101
TASK_CENTER_API_KEY=
